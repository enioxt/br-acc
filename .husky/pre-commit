#!/bin/sh
# EGOS Pre-Commit Canônico v1.0 (POSIX sh compatible)
# Repo: br-acc — Neo4j ETL + API (Python)
# SSOT: egos/.guarani/orchestration/PRE_COMMIT_SPEC.md

set -eu

PRE_START=$(date +%s)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

step_time() { echo "  ⏱️ $(( $(date +%s) - $1 ))s"; }

STAGED_COUNT=$(git diff --cached --name-only | grep -c . 2>/dev/null || echo 0)
if [ "$STAGED_COUNT" -eq 0 ]; then
  echo "  ℹ️ No staged files"
  exit 0
fi

# ============================================
# CHECK 1: Python lint (FAST — non-blocking)
# ============================================
T=$(date +%s)
echo "⚡ [1/5] Python lint..."

HAS_PY=$(git diff --cached --name-only | grep -c '\.py$' 2>/dev/null || echo 0)
if [ "$HAS_PY" -gt 0 ]; then
  if command -v ruff >/dev/null 2>&1; then
    ruff check $(git diff --cached --name-only | grep '\.py$') 2>/dev/null || \
      printf "${YELLOW}⚠️  ruff found issues (non-blocking)${NC}\n"
  elif command -v flake8 >/dev/null 2>&1; then
    flake8 $(git diff --cached --name-only | grep '\.py$') 2>/dev/null || true
  fi
fi
step_time $T

# ============================================
# CHECK 2: Secrets Scan (BLOCKING)
# ============================================
T=$(date +%s)
echo "⚡ [2/5] Secrets scan..."

SECRETS_FOUND=0
MATCHED=$(git diff --cached --name-only | xargs grep -l -E \
  '(sk-[a-zA-Z0-9]{20,}|postgres://[^ ]+|mongodb\+srv://[^ ]+|neo4j\+s://[^ ]+:[^@]+@)' \
  2>/dev/null | grep -vE '\.(env\.example|example|sample)$' | grep -v '\.env' | head -5 || true)
if [ -n "$MATCHED" ]; then
  printf "${RED}❌ BLOCKED: Possible secrets in staged files!${NC}\n"
  echo "$MATCHED"
  SECRETS_FOUND=1
fi

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner 2>/dev/null || SECRETS_FOUND=1
fi

if [ "$SECRETS_FOUND" -eq 1 ]; then exit 1; fi
step_time $T

# ============================================
# CHECK 3: PII Guard (FAST — WARNING)
# ============================================
T=$(date +%s)
echo "⚡ [3/5] PII check..."

# Detect potential CPF/CNPJ patterns committed as literals (not masked)
PII_FILES=$(git diff --cached --name-only | xargs grep -l -E \
  '\b[0-9]{3}\.[0-9]{3}\.[0-9]{3}-[0-9]{2}\b|\b[0-9]{2}\.[0-9]{3}\.[0-9]{3}/[0-9]{4}-[0-9]{2}\b' \
  2>/dev/null | grep -vE '(test|fixture|example|sample|mock)' | head -5 || true)
if [ -n "$PII_FILES" ]; then
  printf "${YELLOW}⚠️  Possible real CPF/CNPJ in staged files (check if test fixtures):${NC}\n"
  echo "$PII_FILES"
fi
step_time $T

# ============================================
# CHECK 4: SSOT Size Limits (FAST — WARNING)
# ============================================
T=$(date +%s)
echo "⚡ [4/5] SSOT size check..."

check_lines() {
  _f="$1"; _max="$2"
  if [ -f "$_f" ]; then
    _l=$(wc -l < "$_f")
    if [ "$_l" -gt "$_max" ]; then
      printf "${YELLOW}⚠️  %s: %s lines (max: %s)${NC}\n" "$_f" "$_l" "$_max"
    fi
  fi
}
check_lines "AGENTS.md" 200
check_lines "TASKS.md" 500
step_time $T

# ============================================
# CHECK 5: EGOS-KERNEL-PROPAGATED freshness
# ============================================
T=$(date +%s)
echo "⚡ [5/5] Kernel sync check..."

if [ -f "CLAUDE.md" ]; then
  MARKER=$(grep "^# EGOS-KERNEL-PROPAGATED:" CLAUDE.md 2>/dev/null | head -1 || true)
  if [ -z "$MARKER" ]; then
    printf "${YELLOW}⚠️  CLAUDE.md missing EGOS-KERNEL-PROPAGATED marker. Run disseminate-propagator.ts.${NC}\n"
  fi
fi
step_time $T

# README freshness gate
bash ~/.egos/hooks/readme-freshness.sh "${1:-}" || exit 1

TOTAL=$(( $(date +%s) - PRE_START ))
printf "${GREEN}✅ br-acc pre-commit: ${TOTAL}s${NC}\n"

# BEGIN egos-phantom-done
# DISSEMINATE-INTEGRITY-002 — Propagated from kernel 2026-06-10
# Bloqueia task [x] marcada sem evidencia verificavel em TASKS.md (phantom-done).
# Evidencia aceita: SHA hex 7-40 chars | Closes/Fixes/Resolves | PR # | URL | "commit <sha>"
# Override consciente: EGOS_PROVENANCE_OVERRIDE=1
if [ -f "TASKS.md" ]; then
  _new_done=$(git diff --cached -U0 -- TASKS.md 2>/dev/null | grep -E '^\+- \[x\]' || true)
  if [ -n "$_new_done" ]; then
    _phantom=$(echo "$_new_done" | grep -vE '\b[0-9a-f]{7,40}\b|Closes|Fixes|Resolves|PR #|https?://|commit ' || true)
    if [ -n "$_phantom" ]; then
      echo "  PROVENANCIA (phantom-done): task(s) marcada(s) [x] SEM evidencia verificavel:"
      echo "$_phantom" | sed 's/^\+- \[x\] \?/    /' | cut -c1-100 | head -5
      echo "     Regra: done exige SHA, arquivo, Closes/Fixes ou prova. Bare data nao conta."
      echo "     -> Reabra [ ] OU adicione evidencia na linha. Override: EGOS_PROVENANCE_OVERRIDE=1"
      [ "${EGOS_PROVENANCE_OVERRIDE:-0}" = "1" ] || { echo "  BLOCKED: phantom-done."; exit 1; }
      echo "  EGOS_PROVENANCE_OVERRIDE=1 -- phantom-done permitido conscientemente."
    fi
  fi
fi
# END egos-phantom-done
