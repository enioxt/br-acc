#!/bin/sh
# EGOS Pre-Commit CanГґnico v1.0 (POSIX sh compatible)
# Repo: br-acc вЂ” Neo4j ETL + API (Python)
# SSOT: egos/.guarani/orchestration/PRE_COMMIT_SPEC.md

set -eu

PRE_START=$(date +%s)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

step_time() { echo "  вЏ±пёЏ $(( $(date +%s) - $1 ))s"; }

STAGED_COUNT=$(git diff --cached --name-only | grep -c . 2>/dev/null || echo 0)
if [ "$STAGED_COUNT" -eq 0 ]; then
  echo "  в„№пёЏ No staged files"
  exit 0
fi

# ============================================
# CHECK 1: Python lint (FAST вЂ” non-blocking)
# ============================================
T=$(date +%s)
echo "вљЎ [1/5] Python lint..."

HAS_PY=$(git diff --cached --name-only | grep -c '\.py$' 2>/dev/null || echo 0)
if [ "$HAS_PY" -gt 0 ]; then
  if command -v ruff >/dev/null 2>&1; then
    ruff check $(git diff --cached --name-only | grep '\.py$') 2>/dev/null || \
      printf "${YELLOW}вљ пёЏ  ruff found issues (non-blocking)${NC}\n"
  elif command -v flake8 >/dev/null 2>&1; then
    flake8 $(git diff --cached --name-only | grep '\.py$') 2>/dev/null || true
  fi
fi
step_time $T

# ============================================
# CHECK 2: Secrets Scan (BLOCKING)
# ============================================
T=$(date +%s)
echo "вљЎ [2/5] Secrets scan..."

SECRETS_FOUND=0
MATCHED=$(git diff --cached --name-only | xargs grep -l -E \
  '(sk-[a-zA-Z0-9]{20,}|postgres://[^ ]+|mongodb\+srv://[^ ]+|neo4j\+s://[^ ]+:[^@]+@)' \
  2>/dev/null | grep -vE '\.(env\.example|example|sample)$' | grep -v '\.env' | head -5 || true)
if [ -n "$MATCHED" ]; then
  printf "${RED}вќЊ BLOCKED: Possible secrets in staged files!${NC}\n"
  echo "$MATCHED"
  SECRETS_FOUND=1
fi

if command -v gitleaks >/dev/null 2>&1; then
  gitleaks protect --staged --no-banner 2>/dev/null || SECRETS_FOUND=1
fi

if [ "$SECRETS_FOUND" -eq 1 ]; then exit 1; fi
step_time $T

# ============================================
# CHECK 3: PII Guard (FAST вЂ” WARNING)
# ============================================
T=$(date +%s)
echo "вљЎ [3/5] PII check..."

# Detect potential CPF/CNPJ patterns committed as literals (not masked)
PII_FILES=$(git diff --cached --name-only | xargs grep -l -E \
  '\b[0-9]{3}\.[0-9]{3}\.[0-9]{3}-[0-9]{2}\b|\b[0-9]{2}\.[0-9]{3}\.[0-9]{3}/[0-9]{4}-[0-9]{2}\b' \
  2>/dev/null | grep -vE '(test|fixture|example|sample|mock)' | head -5 || true)
if [ -n "$PII_FILES" ]; then
  printf "${YELLOW}вљ пёЏ  Possible real CPF/CNPJ in staged files (check if test fixtures):${NC}\n"
  echo "$PII_FILES"
fi
step_time $T

# ============================================
# CHECK 4: SSOT Size Limits (FAST вЂ” WARNING)
# ============================================
T=$(date +%s)
echo "вљЎ [4/5] SSOT size check..."

check_lines() {
  _f="$1"; _max="$2"
  if [ -f "$_f" ]; then
    _l=$(wc -l < "$_f")
    if [ "$_l" -gt "$_max" ]; then
      printf "${YELLOW}вљ пёЏ  %s: %s lines (max: %s)${NC}\n" "$_f" "$_l" "$_max"
    fi
  fi
}
check_lines "AGENTS.md" 200
check_lines "TASKS.md" 500
step_time $T

# ============================================
# CHECK 5: EGOS-KERNEL-PROPAGATED freshness
# ============================================
T=$(date +%s)
echo "вљЎ [5/5] Kernel sync check..."

if [ -f "CLAUDE.md" ]; then
  MARKER=$(grep "^# EGOS-KERNEL-PROPAGATED:" CLAUDE.md 2>/dev/null | head -1 || true)
  if [ -z "$MARKER" ]; then
    printf "${YELLOW}вљ пёЏ  CLAUDE.md missing EGOS-KERNEL-PROPAGATED marker. Run disseminate-propagator.ts.${NC}\n"
  fi
fi
step_time $T

TOTAL=$(( $(date +%s) - PRE_START ))
printf "${GREEN}вњ… br-acc pre-commit: ${TOTAL}s${NC}\n"
