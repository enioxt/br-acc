# PixelArt — Estúdio de vídeos comerciais com IA
pixelart.egos.ia.br {
    # Webhook e API do bot → processo local porta 3099
    handle /webhook/* {
        reverse_proxy 172.19.0.1:3099
    }
    handle /api/* {
        reverse_proxy 172.19.0.1:3099
    }
    handle /health {
        reverse_proxy 172.19.0.1:3099
    }

    # Site estático — landing page
    handle {
        root * /opt/pixelart/site
        file_server
    }

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
        -Server
        -X-Powered-By
    }
}


# EGOS Lab landing page + chat API
lab.egos.ia.br {
    # Chat API — strip /api prefix before proxying
    handle_path /api/* {
        reverse_proxy egos-lab-chat:3095
    }

    # Assets: serve direto, sem fallback (evita CSS cache-break)
    handle /assets/* {
        root * /opt/egos-lab
        file_server
    }

    # SPA routes: fallback para index.html
    handle {
        root * /opt/egos-lab
        try_files {path} /index.html
        file_server
    }

    header {
        X-Content-Type-Options nosniff
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type"
        -Server
        -X-Powered-By
    }
}

